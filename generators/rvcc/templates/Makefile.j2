#
# WARNING : Generated by rvcc generator

# -----------------------------------------------------------------------------
# Tools
# -----------------------------------------------------------------------------
RISCV_PREFIX     = {{ riscv_prefix }}
CC               = $(RISCV_PREFIX)gcc
AS               = $(RISCV_PREFIX)as
LD               = $(RISCV_PREFIX)ld
OBJDUMP          = $(RISCV_PREFIX)objdump
OBJCOPY          = $(RISCV_PREFIX)objcopy
READELF          = $(RISCV_PREFIX)readelf

HEX2VHD_TOOL     = {{ hex2vhd_tool }}
ROM_MODEL        = {{ rom_model_vhd }}
ROM_ENTITY       = {{ rom_entity }}

# -----------------------------------------------------------------------------
# Flags
# -----------------------------------------------------------------------------
CFLAGS           = -march=rv32i_zicsr              # RISC-V 32-bit integer base architecture
CFLAGS          += -mabi=ilp32                     # Standard 32-bit ABI (int, long, pointers are 32-bit)
CFLAGS          += -O2                             # Level 2 optimization for performance
CFLAGS          += -ffreestanding                  # OS-less environment (no full standard library)
CFLAGS          += -nostartfiles                   # Do not use standard startup files (crt0...)
CFLAGS          += -nostdlib                       # Do not link standard libraries
CFLAGS          += -fverbose-asm                   # Add explanatory comments in generated assembly
CFLAGS          += -Wall                           # Enable all basic warnings
CFLAGS          += -Wextra                         # Enable extra warnings
CFLAGS          += -Werror                         # Treat warnings as errors
CFLAGS          += -Wno-error=array-bounds         # Ignore array-bounds errors
CFLAGS          += -fno-delete-null-pointer-checks # Disable null pointer checks
CFLAGS          += -static                         # Statically link libraries
CFLAGS          += -mcmodel=medany                 # Code model to address anywhere within a 2 GB range
CFLAGS          += $(INCLUDES)
CFLAGS          += {{ cflags }}

# -----------------------------------------------------------------------------
# Files
# -----------------------------------------------------------------------------
BUILD_DIR        = build

INPUT_FILE       = {{ input_file_path }}
SRC              = {{ start_s_file }}
SRC             += $(INPUT_FILE)

OUTPUT_BASENAME  = {{ output_base_name }}

ELF              = $(BUILD_DIR)/$(OUTPUT_BASENAME).elf
BIN              = $(BUILD_DIR)/$(OUTPUT_BASENAME).bin
HEX              = $(BUILD_DIR)/$(OUTPUT_BASENAME).hex
LST              = $(BUILD_DIR)/$(OUTPUT_BASENAME).lst
SIZE             = $(BUILD_DIR)/$(OUTPUT_BASENAME).size
ASM              = $(BUILD_DIR)/$(notdir $(INPUT_FILE)).s
VHD              = {{ output_vhd_file}}

FILE_TYPE        = {{ file_type }}

LINK_LD_FILE     = {{ link_ld_file }}

# -----------------------------------------------------------------------------
# RULES
# -----------------------------------------------------------------------------
all: $(HEX) $(LST) $(ASM) $(SIZE) $(VHD)

# Compilation and Linking
$(ELF): $(SRC) $(LINK_LD_FILE) | $(BUILD_DIR)
	$(CC) $(CFLAGS) -T $(LINK_LD_FILE) -o $@ $(SRC)

# Pure binary extraction
$(BIN): $(ELF) | $(BUILD_DIR)
	$(OBJCOPY) -O binary $< $@

# Hexadecimal conversion (32-bit text format per line for VHDL)
# hexdump reads 4 bytes and displays them in hexadecimal on one line
$(HEX): $(BIN) | $(BUILD_DIR)
	hexdump -v -e '1/4 "%08x\n"' $< > $@

# Disassembly with source (Listing)
$(LST): $(ELF) | $(BUILD_DIR)
	$(OBJDUMP) -d -S $< > $@

# Section size and content information
$(SIZE): $(ELF) | $(BUILD_DIR)
	$(READELF) -S $< > $@

# Commented assembly file (GCC output)
$(ASM): $(INPUT_FILE) | $(BUILD_DIR)
	$(CC) $(CFLAGS) -S $(INPUT_FILE) -o $@

# ROM Generation
$(VHD): $(HEX) $(ROM_MODEL) | $(BUILD_DIR)
	$(HEX2VHD_TOOL) $< $(ROM_MODEL) $(ROM_ENTITY) $@

$(BUILD_DIR) :
	mkdir -p $@

clean:
	rm -fr $(BUILD_DIR)
